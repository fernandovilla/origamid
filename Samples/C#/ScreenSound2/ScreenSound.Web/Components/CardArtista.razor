<MudCard Class="mb-5">

    <MudCardMedia Image="@Imagem"></MudCardMedia>
    
    <MudCardHeader>
        <MudText Typo="Typo.h6">@Artista!.Nome</MudText>
    </MudCardHeader>

    <MudCardContent>
        <MudText Typo="Typo.body2">@Artista!.Bio</MudText>
    </MudCardContent>

    <MudCardActions>
        <MudButton Href=@($"/EdicaoArtista/{Artista.Id}")
                   Color="Color.Warning" Variant="Variant.Outlined">
            Detalhes
        </MudButton>
    </MudCardActions>

</MudCard>



@code {
    [Parameter]
    public ArtistaResponse? Artista { get; set; }

    public string? Imagem { get; set; }

    // protected override Task OnInitializedAsync()
    // {
    //     if (Artista != null) {

    //         // if (Artista.Nome == "Ana Castela")
    //         // {

    //         // }

    //         // var im = Artista.FotoPerfil.Contains("Foto") ? $"https://localhost:7080/FotosPerfil/{Artista.FotoPerfil}" : "imagens//musico-default.jpg";

    //         // Imagem = Artista.FotoPerfil.Contains("Foto") ? $"https://localhost:7080/FotosPerfil/{Artista.FotoPerfil}" : "imagens//musico-default.jpg";
    //     }

    //     return null;
    // }


    protected override void OnInitialized()
    {
        if (Artista != null)
        {
            if (Artista.FotoPerfil.StartsWith($"{Artista.Id}_"))
            {
                {
                    Imagem = Artista.FotoPerfil.StartsWith("http") == false ? $"https://localhost:7080/FotosPerfil/{Artista.FotoPerfil}" : "https://localhost:7164/imagens//musico-default.jpg";
                    return;
                }
            }

            Imagem = "/images/musico-default.jpg";
        }
    }
}
